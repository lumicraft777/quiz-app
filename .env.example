# scripts/sync-questions.js を実行する前に、このファイルを .env という
# 名前でコピーし、実際の値を入れてください。
# .env はgitで管理しません（.gitignoreに含まれています）。絶対にコミットしないこと。

# SupabaseプロジェクトのURL（例: https://xxxxx.supabase.co）
SUPABASE_URL=

# secret key（旧: service_role key）。RLSを無視して書き込める管理者権限のキー。
# 同期スクリプト以外（アプリ本体・ブラウザ側）では絶対に使わないこと。
SUPABASE_SECRET_KEY=
